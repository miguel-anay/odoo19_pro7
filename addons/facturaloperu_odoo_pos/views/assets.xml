<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="assets_backend" name="facturaloperu_odoo_pos_assets" inherit_id="web.assets_backend">
    <xpath expr="." position="inside">
      <link rel="stylesheet" href="/facturaloperu_odoo_pos/static/src/css/api_frame.css"/>
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/js/db.js"/>
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/js/gui.js"/>
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/js/screen.js"/>
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/js/models.js"/>
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/js/chrome.js"/>
    </xpath>
  </template>

  <template id="pos_facturalo_assets" inherit_id="point_of_sale.assets">
    <xpath expr="." position="inside">
      <script type="text/javascript" src="/facturaloperu_odoo_pos/static/src/libs/noty/noty.min.js"/>
    </xpath>
    <xpath expr="//link[@id='pos-stylesheet']" position="after">
      <link rel="stylesheet" href="/facturaloperu_odoo_pos/static/src/css/pos.css"/>
      <link rel="stylesheet" type="text/css" href="/facturaloperu_odoo_pos/static/src/libs/noty/noty.css"/>
      <link rel="stylesheet" type="text/css" href="/facturaloperu_odoo_pos/static/src/libs/noty/themes/bootstrap-v4.css"/>
    </xpath>
  </template>
</odoo>
