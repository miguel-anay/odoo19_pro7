            <field name="name">Configuration of Peruvian Datas</field>
            <field name="description">Set up peruvian datas</field>
            <field name="sequence">20</field>
        </record>
        <record id="group_l10n_pe_datas_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_l10n_pe_datas"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_l10n_pe_datas_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_l10n_pe_datas"/>
