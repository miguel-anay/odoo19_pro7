<odoo>
  <data>

    <!-- FACTURAS ACCOUNT.MOVE -->
    <record id="facturaloperu_odoo_facturacion.account_invoice" model="ir.ui.view">
      <field name="name">account.move.form.view.inherit</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <xpath expr="//page[1]" position="after">
          <page string="API">
            <group>
              <group>
                <field name="number_feapi" />
                <field name="external_id" groups="base.group_no_one"/>
                <field name="format_pdf" widget="selection" invisible="state_api != 'register'"/>
                <field name="l10n_pe_invoice_origin_id" invisible="not l10n_pe_invoice_origin_id"/>
                <field name="l10n_pe_debit_note_code" invisible="not l10n_pe_debit_note_code"/>
                <field name="l10n_pe_credit_note_code" invisible="not l10n_pe_credit_note_code"/>
              </group>
              <group>
                <field name="link_cdr" widget="url" invisible="state_api != 'success'"/>
                <field name="link_pdf" widget="url" invisible="not external_id"/>
                <field name="link_xml" widget="url" invisible="not external_id"/>
                <field name="enable_voided_document" invisible="1"/>
                <field name="ticket_voided_document" invisible="1"/>
                <field name="link_voided_document" widget="url" invisible="not ticket_voided_document"/>
              </group>
            </group>
            <group>
              <group>
                <field name="state_api_can_update" groups="base.group_no_one"/>
              </group>
              <group>
              </group>
            </group>
          </page>
        </xpath>
        <xpath expr="//page[1]" position="after">
          <page string="API JSON">
            <group>
              <field name="api_json" widget="ace"/>
            </group>
          </page>
        </xpath>
        <xpath expr="//page[1]" position="after">
          <page string="Administrar estado" invisible="state == 'draft' or not state_api_can_update">
            <group>
              <group>
                <field name="state_api_update"/>
              </group>
              <group>
                <button name="action_invoice_update_state" type="object" string="Actualizar Estado"/>
              </group>
            </group>
          </page>
        </xpath>
      </field>
    </record>

    <!-- Rename standard Odoo Send button to "Enviar correo" -->
    <record id="facturaloperu_odoo_facturacion.account_move_send_rename" model="ir.ui.view">
      <field name="name">account.move.form.send.rename</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="priority">98</field>
      <field name="arch" type="xml">
        <xpath expr="//button[@name='action_invoice_sent'][@class='oe_highlight']" position="attributes">
          <attribute name="string">Enviar correo</attribute>
        </xpath>
        <xpath expr="//button[@name='action_invoice_sent'][not(@class)]" position="attributes">
          <attribute name="string">Enviar correo</attribute>
        </xpath>
      </field>
    </record>

    <!-- Mostrar Serie-Correlativo SUNAT (ej: F002-00000046) bajo el título -->
    <record id="facturaloperu_odoo_facturacion.account_move_feapi_number" model="ir.ui.view">
      <field name="name">account.move.form.feapi.number</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="priority">97</field>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <div invisible="not feapi_display_number" style="margin-top:2px;">
            <field name="feapi_display_number" readonly="1"
                   style="font-size:1.1em; font-weight:600; color:#017e84;"/>
          </div>
        </xpath>
      </field>
    </record>

    <!-- Header buttons for SUNAT operations -->
    <record id="facturaloperu_odoo_facturacion.account_move_header" model="ir.ui.view">
      <field name="name">account.move.form.header.inherit</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="priority">99</field>
      <field name="arch" type="xml">
        <!-- Ocultar la barra de estado estándar de Odoo (draft/posted) -->
        <xpath expr="//field[@name='state'][@widget='statusbar']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <!-- Barra SUNAT única con todos los estados -->
        <xpath expr="//header" position="inside">
          <field name="state_api" widget="statusbar"
                 statusbar_visible="register,send,success,observed,reject,null"/>
          <button name="action_invoice_send_sunat" type="object" string="Enviar SUNAT" class="oe_highlight" groups="account.group_account_invoice" invisible="state == 'draft' or state_api in ('send','null','success','reject')"/>
          <button name="action_invoice_json_generate" type="object" string="Json generado" groups="account.group_account_invoice" invisible="state == 'draft' or state_api == 'send'"/>
          <button name="action_print_invoice_sunat" type="object" string="PDF-A4" invisible="state == 'draft' or state_api == 'register' or not number_feapi"/>
          <button name="action_print_invoice_ticket" type="object" string="PDF Ticket" invisible="state == 'draft' or state_api == 'register' or not number_feapi"/>
          <button name="void_document" type="object" string="Anular factura" groups="account.group_account_invoice" invisible="not enable_voided_document"/>
          <button name="action_invoice_query_status" type="object" string="Consultar estado en API" class="oe_highlight" groups="account.group_account_invoice" invisible="state == 'draft' or not external_id"/>
        </xpath>
      </field>
    </record>

  </data>
</odoo>
