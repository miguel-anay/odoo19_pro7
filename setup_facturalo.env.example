# ============================================================
# setup_facturalo.env.example
# Copiar a setup_facturalo.env y completar con datos reales
# ============================================================

# --- Conexión Odoo ---
ODOO_URL=http://localhost:8069
ODOO_DB=fp_bd
ODOO_USER=admin
ODOO_PASSWORD=admin

# --- API FacturaloPeru PRO ---
# URL base del Facturador (sin slash al final)
API_URL=https://yiwu.qhipa.org.pe

# Token obtenido desde el panel del Facturador PRO
API_TOKEN=COLOCA_TU_TOKEN_AQUI

# Enviar comprobante por email al cliente (true/false)
API_SEND_EMAIL=false

# Token para consulta DNI/RUC en apiperu.dev (opcional)
APIPERU_TOKEN=

# --- Datos de la empresa ---
COMPANY_NAME=Mi Empresa SAC
COMPANY_VAT=20123456789
COMPANY_STREET=Av. Principal 123
COMPANY_CITY=Lima
COMPANY_PHONE=01-1234567
COMPANY_EMAIL=empresa@gmail.com

# --- Almacén principal (Guías de Remisión) ---
# Código de establecimiento registrado en SUNAT
WAREHOUSE_ESTABLISHMENT_CODE=0000

# --- POS (Punto de Venta) ---
# Nombre del POS a configurar (dejar vacío para configurar el primero que encuentre)
POS_NAME=

# URL del endpoint para POS (generalmente API_URL + /api/documents)
POS_API_URL=
# Si está vacío se usa: API_URL + /api/documents automáticamente

# Token para POS (si está vacío usa API_TOKEN)
POS_API_TOKEN=
